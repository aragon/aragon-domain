{
  "name": "@aragon/aragon-subdomain",
  "version": "0.2.0",
  "description": "Aragon governance business logic package — domain model, use cases, and infrastructure adapters",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "license": "GPL-3.0",
  "author": "Aragon Association",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
    "lint:ci": "biome ci --no-errors-on-unmatched --files-ignore-unknown=true",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "changeset": "changeset"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aragon/aragon-subdomain.git"
  },
  "bugs": {
    "url": "https://github.com/aragon/aragon-subdomain/issues"
  },
  "homepage": "https://github.com/aragon/aragon-subdomain#readme",
  "dependencies": {
    "bignumber.js": "11.1.2",
    "ddd-core-ts": "0.1.1",
    "graphql": "16.14.1",
    "graphql-request": "7.4.0",
    "viem": "2.52.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "24.13.0",
    "@vitest/coverage-v8": "3.2.6",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  },
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
