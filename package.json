{
  "name": "@aragon/aragon-subdomain",
  "version": "0.1.0",
  "description": "Aragon governance business logic package — domain model, use cases, and infrastructure adapters",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "license": "GPL-3.0",
  "author": "Aragon Association",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
    "lint:ci": "biome ci --no-errors-on-unmatched --files-ignore-unknown=true",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "changeset": "changeset"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aragon/aragon-subdomain.git"
  },
  "bugs": {
    "url": "https://github.com/aragon/aragon-subdomain/issues"
  },
  "homepage": "https://github.com/aragon/aragon-subdomain#readme",
  "dependencies": {
    "bignumber.js": "11.0.0",
    "ddd-core-ts": "0.1.1",
    "graphql": "16.13.2",
    "graphql-request": "7.4.0",
    "viem": "2.52.0",
    "zod": "3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "20.8.8",
    "@vitest/coverage-v8": "2.1.9",
    "tsup": "8.5.1",
    "typescript": "5.4.5",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
