{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "includes": [
      "**",
      "!*.json",
      "!*.jsonc"
    ]
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2,
      "expand": "always"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    },
    "globals": [
      "jest",
      "describe",
      "it",
      "test",
      "expect",
      "beforeEach",
      "afterEach",
      "beforeAll",
      "afterAll"
    ]
  },
  "linter": {
    "rules": {
      "recommended": true,
      "complexity": {
        "noUselessStringConcat": "warn",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUndeclaredVariables": "error"
      },
      "style": {
        "noCommonJs": "error",
        "noInferrableTypes": "error",
        "noNamespace": "error",
        "noNonNullAssertion": "off",
        "useAsConstAssertion": "error",
        "useBlockStatements": "warn",
        "useConsistentArrayType": "error",
        "useConsistentTypeDefinitions": {
          "level": "warn",
          "options": {
            "style": "interface"
          }
        },
        "useForOf": "error",
        "useTemplate": "warn",
        "useUnifiedTypeSignatures": "error"
      },
      "suspicious": {
        "noAssignInExpressions": "off",
        "noConsole": "warn",
        "noConstantBinaryExpressions": "error",
        "noEmptyBlockStatements": "error",
        "noEmptyInterface": "off",
        "noImplicitAnyLet": "off",
        "useAwait": "error",
        "useIterableCallbackReturn": "off"
      },
      "performance": {
        "noAccumulatingSpread": "off"
      }
    },
    "includes": [
      "**",
      "!node_modules",
      "!dist/**/*",
      "!coverage"
    ]
  },
  "overrides": [
    {
      "includes": [
        "**/*.ts",
        "**/*.mts",
        "**/*.cts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noArguments": "error"
          },
          "correctness": {
            "noConstAssign": "off",
            "noGlobalObjectCalls": "off",
            "noInvalidBuiltinInstantiation": "off",
            "noInvalidConstructorSuper": "off",
            "noSetterReturn": "off",
            "noUndeclaredVariables": "off",
            "noUnreachable": "off",
            "noUnreachableSuper": "off"
          },
          "style": {
            "useConst": "error"
          },
          "suspicious": {
            "noClassAssign": "off",
            "noDuplicateClassMembers": "off",
            "noDuplicateObjectKeys": "off",
            "noDuplicateParameters": "off",
            "noFunctionAssign": "off",
            "noImportAssign": "off",
            "noRedeclare": "off",
            "noUnsafeNegation": "off",
            "noVar": "error",
            "noWith": "off",
            "useGetterReturn": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/*.test.ts"
      ],
      "linter": {
        "rules": {}
      }
    },
    {
      "includes": [
        "src/domain/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/use-cases/**"
                    ],
                    "message": "Domain layer must not import from use-cases. Dependencies flow inward: infrastructure → use-cases → domain."
                  },
                  {
                    "group": [
                      "@/infrastructure/**"
                    ],
                    "message": "Domain layer must not import from infrastructure. Dependencies flow inward: infrastructure → use-cases → domain."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/use-cases/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/infrastructure/**"
                    ],
                    "message": "Use-cases layer must not import from infrastructure. Dependencies flow inward: infrastructure → use-cases → domain."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedAttributes": "on"
      }
    }
  }
}
